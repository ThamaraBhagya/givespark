// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//User

model User {
  id          String      @id @default(cuid())
  name        String
  email       String      @unique
  password    String
  emailVerified    DateTime?     // If using credentials
  image       String?
  role        Role        @default(USER) // Will be USER or CREATOR

  // 💡 NEW FIELD for Stripe Connect
  stripeAccountId String?
  
  campaigns   Campaign[]  @relation("UserCampaigns")
  donations   Donation[]  @relation("UserDonations")
  wallet      Wallet?     // Creator wallet
  accounts         Account[]
  sessions         Session[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// User roles
enum Role {
  USER
  CREATOR
}

// ---------- 2. ACCOUNT Model (New - Required for NextAuth Adapter) ----------
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// ADD THESE MODELS to your prisma/schema.prisma file

// ---------- 3. SESSION Model (Required for NextAuth Adapter) ----------
model Session {
  id           String    @id @default(cuid())
  sessionToken String    @unique
  userId       String
  expires      DateTime
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ---------- 4. VERIFICATION TOKEN Model (Required for NextAuth Adapter) ----------
model VerificationToken {
  identifier String
  token      String    @unique
  expires    DateTime

  @@unique([identifier, token])
}
enum Category {
  EDUCATION
  MEDICAL
  TECHNOLOGY
  COMMUNITY
  OTHER
}

// 2. CAMPAIGN 
model Campaign {
  id             String       @id @default(cuid())
  title          String
  shortDesc      String
  description    String
  goalAmount     Float
  currentAmount  Float        @default(0)
  
  deadline       DateTime
  featuredImage  String
  images         String[]
  category       Category @default(OTHER)

  creatorId      String
  creator        User         @relation("UserCampaigns", fields: [creatorId], references: [id])

  donations      Donation[]

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// 3. DONATION (Mock Payment Record)
model Donation {
  id          String     @id @default(cuid())
  amount      Float
  message     String?
  anonymous   Boolean    @default(false)

  // 💡 NEW FIELD: Link to the Stripe transaction ID
  stripePaymentIntentId String?  @unique

  donorId     String?
  donor       User?       @relation("UserDonations", fields: [donorId], references: [id])

  campaignId  String
  campaign    Campaign    @relation(fields: [campaignId], references: [id])

  createdAt   DateTime   @default(now())
}



// 4. WALLET (Virtual Creator Wallet)
model Wallet {
  id              String     @id @default(cuid())
  balance         Float      @default(0)
  totalReceived   Float      @default(0)
  withdrawnAmount Float      @default(0)

  userId          String     @unique
  user            User       @relation(fields: [userId], references: [id])

  transactions    WalletTransaction[]
  updatedAt       DateTime   @updatedAt
}

// 5. WALLET TRANSACTIONS (Withdraw logs)
model WalletTransaction {
  id          String     @id @default(cuid())
  amount      Float
  type          TransactionType
  createdAt   DateTime   @default(now())

  // 💡 NEW FIELDS: For linking the transaction to its source (Donation/Stripe ID)
  sourceId      String?   // The ID of the related object (e.g., Donation ID or Stripe Intent ID)
  sourceType    String?   // e.g., 'DONATION', 'STRIPE_FEE'

  walletId    String
  wallet      Wallet     @relation(fields: [walletId], references: [id])
}


enum TransactionType {
  DEPOSIT
  WITHDRAW
}





